rules_version = '2';

// Security rules for the WeTalk chat app.
// Goal: logged-in users only, and a chat is private to its two participants.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- USERS ----
    // Anyone logged in can READ the user list (needed to show who to chat with).
    // You can only WRITE (create/update) your OWN profile document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ---- CHATS ----
    // A chat document's ID is the two user ids sorted and joined: "uidA_uidB".
    // Reading the chat list relies on the `participants` field (used by the
    // app's array-contains query); creating/updating relies on the id itself.
    match /chats/{chatId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow write: if request.auth != null
        && request.auth.uid in chatId.split('_');

      // ---- MESSAGES inside a chat ----
      // Only the two people in that chat (encoded in the chatId) can
      // read or write its messages.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in chatId.split('_');
      }
    }

    // ---- GROUPS ----
    // A group has a `members` list of user ids. Only members can read it or
    // its messages. Anyone logged in can CREATE a group as long as they put
    // themselves in the members list. Members can update (send/leave) or
    // delete the group.
    match /groups/{groupId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Messages inside a group: only current members may read or write.
      // get() looks up the parent group doc to check its members list.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }
  }
}
