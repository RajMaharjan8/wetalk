rules_version = '2';

// Security rules for the WeTalk chat app.
// Goal: logged-in users only, and a chat is private to its two participants.
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- USERS ----
    // Read is open so both logged-in users (to show who to chat with) and the
    // admin panel — which has its own username/password gate and NO Firebase
    // login — can list users.
    // A signed-in user may only CREATE/UPDATE their OWN profile document.
    // The admin panel has no Firebase identity, so banning (update) and
    // removing (delete) an account are left open.
    // NOTE: open update/delete means anyone could call them. That's acceptable
    // for this simple/learning setup but is NOT production-safe — for real
    // security move ban/delete behind Firebase custom claims or the Admin SDK.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if true;
    }

    // ---- CHATS ----
    // A chat document's ID is the two user ids sorted and joined: "uidA_uidB".
    // Reading the chat list relies on the `participants` field (used by the
    // app's array-contains query); creating/updating relies on the id itself.
    match /chats/{chatId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participants;
      allow write: if request.auth != null
        && request.auth.uid in chatId.split('_');

      // ---- MESSAGES inside a chat ----
      // Only the two people in that chat (encoded in the chatId) can
      // read or write its messages.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in chatId.split('_');
      }

      // ---- GAME state (Monopoly, Rock-Paper-Scissors, …) inside a chat ----
      // One doc per game (game/monopoly, game/rps). Same access as messages:
      // only the two players in the chat.
      match /game/{docId} {
        allow read, write: if request.auth != null
          && request.auth.uid in chatId.split('_');
      }
    }

    // ---- GROUPS ----
    // A group has a `members` list of user ids. Only members can read it or
    // its messages. Anyone logged in can CREATE a group as long as they put
    // themselves in the members list. Members can update (send/leave) or
    // delete the group.
    match /groups/{groupId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      // Messages inside a group: only current members may read or write.
      // get() looks up the parent group doc to check its members list.
      match /messages/{messageId} {
        allow read, write: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/groups/$(groupId)).data.members;
      }
    }
  }
}
